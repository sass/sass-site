{
  "extends": "./node_modules/gts/tsconfig-google.json",
  "ts-node": {
    "transpileOnly": true
  },
  "compilerOptions": {
    "rootDir": ".",
    "esModuleInterop": true,
    "target": "es2022",
    "lib": ["es2022", "DOM"],
    "isolatedModules": true,
    "noEmit": true,
    "types": ["jquery", "node", "jqueryui"]
  },
  "include": ["source/**/*.ts", "tool/*.ts"],
  "exclude": ["node_modules"]
}
